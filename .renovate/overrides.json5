{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Override Helmfile Dependency Name",
      matchDatasources: [
        "docker"
      ],
      matchManagers: [
        "helmfile"
      ],
      overrideDepName: "{{packageName}}",
    },
    {
      "description": "Separate Major/Minor/Patch for CNPG PostgreSQL image upgrades",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/postgresql"
      ],
      "separateMajorMinor": true,
      "separateMinorPatch": true,
      "separateMultipleMajor": true,
      "separateMultipleMinor": true
    },
    {
      description: "Ignore Rancher shell images >= 7.0.0",
      matchDatasources: [
        "docker"
      ],
      matchPackageNames: [
        "docker.io/rancher/shell"
      ],
      allowedVersions: "<7.0.0",
    },
    // {
    //   // Handle Dispatcharr tags
    //   // https://docs.renovatebot.com/modules/versioning/regex/
    //   matchDatasources: [
    //     "docker"
    //   ],
    //   matchPackageNames: [
    //     "ghcr.io/dispatcharr/dispatcharr"
    //   ],
    //   versioning: "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-(?<build>\\d+)$",
    // },
    {
      // Handle EnhancedChannelManager tags
      // https://docs.renovatebot.com/modules/versioning/regex/
      matchDatasources: [
        "docker"
      ],
      matchPackageNames: [
        "ghcr.io/motwakorb/enhancedchannelmanager",
        "ghcr.io/motwakorb/enhancedchannelmanager-mcp"
      ],
      versioning: "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-(?<build>[0-9A-Za-z.-]+)$",
      // Block the entire 0.18.x train (stable AND -dev) without re-introducing
      // the <0.18.0 filter — that one falls back to npm semver and silently
      // rejects every -dev build of <0.18.0, including legitimate 0.17.6-0057-dev, etc.
      ignoreVersions: [
        "^0\\.18\\..*$",
      ],
    },
  ],
}
